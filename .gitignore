# =============================================================================
# .gitignore  —  Place in your project root AND in devops/ folder
# =============================================================================

# ── Secret files — NEVER commit these ────────────────────────────────────────
.env
.env.prod
*.env.local

# ── Built JARs ───────────────────────────────────────────────────────────────
**/target/*.jar
**/target/

# ── Docker volumes ────────────────────────────────────────────────────────────
postgres-data/

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
.idea/
*.iml
