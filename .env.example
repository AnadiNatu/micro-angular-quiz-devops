# =============================================================================
# .env.example  —  PLACEHOLDER FILE (safe to commit to Git)
# Copy this to .env and fill in real values — NEVER commit .env
# =============================================================================

# ── PostgreSQL (Docker local / AWS RDS) ──────────────────────────────────────
POSTGRES_HOST=postgres                  # docker: 'postgres' | AWS RDS: your-rds-endpoint.rds.amazonaws.com
POSTGRES_PORT=5432

# Auth Service DB
AUTH_DB_NAME=auth_db
AUTH_DB_USER=auth_user
AUTH_DB_PASSWORD=CHANGE_ME_AUTH_PASS

# Question Service DB
QUESTION_DB_NAME=question_db
QUESTION_DB_USER=question_user
QUESTION_DB_PASSWORD=CHANGE_ME_QUESTION_PASS

# Quiz Service DB
QUIZ_DB_NAME=quiz_db
QUIZ_DB_USER=quiz_user
QUIZ_DB_PASSWORD=CHANGE_ME_QUIZ_PASS

# Notification Service DB (no DB needed — stateless, but keep for future)
# NOTIFICATION_DB_NAME=notification_db

# Postgres superuser (Docker only — NOT used on RDS)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_ROOT

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be the SAME secret in all services (min 32 chars)
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS_LONG

# ── Spring Mail (SMTP) ───────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=CHANGE_ME_APP_PASSWORD

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME_sk-xxxxxxxxxxxx

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=CHANGE_ME_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_SECRET_KEY
AWS_REGION=ap-south-1

# S3 (if using Cloudinary or S3 for profile photos)
AWS_S3_BUCKET=CHANGE_ME_BUCKET_NAME

# ── Eureka (Service Discovery) ───────────────────────────────────────────────
EUREKA_HOST=api-gateway              # docker service name
EUREKA_PORT=8761                     # if running separate eureka; 8080 if embedded

# ── Spring Profiles ──────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=docker        # local | docker | prod

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=80
API_GATEWAY_URL=http://api-gateway:8080   # internal docker network URL
